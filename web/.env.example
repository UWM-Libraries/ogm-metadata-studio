# Google Sign-In (optional). Create a Web application OAuth 2.0 Client ID at
# https://console.cloud.google.com/apis/credentials and add authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# Optional: comma/space-separated list of Google account emails allowed to sign in.
# If not set, defaults to "ewlarson@gmail.com".
# Example:
# VITE_GOOGLE_ALLOWED_EMAILS=alice@example.com,bob@example.com
VITE_GOOGLE_ALLOWED_EMAILS=

# Enrichment workbench browser setting (optional).
# Defaults to http://localhost:8787 if omitted.
VITE_ENRICHMENT_PROXY_URL=http://localhost:8787

# Local enrichment proxy settings (optional).
# The proxy loads web/.env and web/.env.local when started with `npm run proxy`.
ENRICHMENT_PROXY_PORT=8787
# ENRICHMENT_PROXY_CONFIG=./local-enrichment.config.json
# ENRICHMENT_PROXY_MOCK_OPENAI=1

# OpenAI profile secrets. The proxy config stores the env var name, not the value.
OPENAI_API_KEY=

# S3-compatible storage secrets. Storage profiles can point at these env var names.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
