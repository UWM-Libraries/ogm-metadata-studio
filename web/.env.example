# Google Sign-In (optional). Create a Web application OAuth 2.0 Client ID at
# https://console.cloud.google.com/apis/credentials and add authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# Optional: comma/space-separated list of Google account emails allowed to sign in.
# If not set, defaults to "ewlarson@gmail.com".
# Example:
# VITE_GOOGLE_ALLOWED_EMAILS=alice@example.com,bob@example.com
VITE_GOOGLE_ALLOWED_EMAILS=

# Enrichment workbench browser setting (optional).
# Defaults to http://localhost:8787 if omitted.
VITE_ENRICHMENT_PROXY_URL=http://localhost:8787

# Local enrichment proxy settings (optional).
# The proxy loads web/.env and web/.env.local when started with `npm run proxy`.
ENRICHMENT_PROXY_PORT=8787
# ENRICHMENT_PROXY_CONFIG=./local-enrichment.config.json
# ENRICHMENT_PROXY_MOCK_OPENAI=1
# ENRICHMENT_PROXY_S3_LIST_TIMEOUT_MS=30000
# ENRICHMENT_PROXY_S3_OBJECT_TIMEOUT_MS=120000
# ENRICHMENT_PROXY_MAX_LIST_PAGES=1000
# Optional local Who's On First concordance index. Default path:
# web/.cache/gazetteers/wof/index.ndjson
# ENRICHMENT_PROXY_WOF_CONCORDANCE=1
# ENRICHMENT_PROXY_WOF_INDEX_PATH=./.cache/gazetteers/wof/index.ndjson
# ENRICHMENT_PROXY_WOF_INDEX_LABEL=wof-seattle
# ENRICHMENT_PROXY_WOF_MATCH_THRESHOLD=0.78
# ENRICHMENT_PROXY_WOF_AMBIGUOUS_THRESHOLD=0.62
# ENRICHMENT_PROXY_WOF_BOUNDARY_SCAN_LIMIT=2500
# For large indexes, supplemental OCR labels use exact normalized WOF-name hits
# unless the index has at most this many records.
# ENRICHMENT_PROXY_WOF_SUPPLEMENTAL_FUZZY_MAX_RECORDS=15000
# Optional local OpenStreetMap fallback concordance index. Default path:
# web/.cache/gazetteers/osm/index.ndjson
# ENRICHMENT_PROXY_OSM_CONCORDANCE=1
# ENRICHMENT_PROXY_OSM_INDEX_PATH=./.cache/gazetteers/osm/index.ndjson
# ENRICHMENT_PROXY_OSM_INDEX_LABEL=osm-seattle
# ENRICHMENT_PROXY_OSM_MATCH_THRESHOLD=0.8
# ENRICHMENT_PROXY_OSM_AMBIGUOUS_THRESHOLD=0.66
# ENRICHMENT_PROXY_OSM_TEXT_CONFIDENCE=0.84
# Optional local GeoNames concordance index. Default path:
# web/.cache/gazetteers/geonames/index.ndjson
# ENRICHMENT_PROXY_GEONAMES_CONCORDANCE=1
# ENRICHMENT_PROXY_GEONAMES_INDEX_PATH=./.cache/gazetteers/geonames/index.ndjson
# ENRICHMENT_PROXY_GEONAMES_INDEX_LABEL=geonames-seattle
# ENRICHMENT_PROXY_GEONAMES_MATCH_THRESHOLD=0.79
# ENRICHMENT_PROXY_GEONAMES_AMBIGUOUS_THRESHOLD=0.66
# ENRICHMENT_PROXY_GEONAMES_TEXT_CONFIDENCE=0.84

# OpenAI profile secrets. Put the value here; put OPENAI_API_KEY in the UI profile field.
OPENAI_API_KEY=

# Optional Google Cloud Vision OCR profile secret. Put the value here; put
# GOOGLE_CLOUD_VISION_API_KEY in the UI profile field.
GOOGLE_CLOUD_VISION_API_KEY=

# S3-compatible storage secrets. Put values here; put these variable names in the UI profile fields.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
