{
  "name": "opengeometadata-studio",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "@samvera/clover-iiif": "3.3.0"
  },
  "scripts": {
    "build:db": "node ./scripts/build-db.cjs",
    "build:wof-index": "python3 ./scripts/build-wof-index.py",
    "build:osm-index": "node ./scripts/build-osm-index.mjs",
    "build:geonames-index": "node ./scripts/build-geonames-index.mjs",
    "build:gnis-index": "node ./scripts/build-gnis-index.mjs",
    "build:wikidata-index": "node ./scripts/build-wikidata-index.mjs",
    "build:canonical-gazetteer": "node ./scripts/build-canonical-gazetteer.mjs",
    "eval:canonical-gazetteer": "node ./scripts/evaluate-canonical-gazetteer.mjs",
    "audit:canonical-gazetteer": "node ./scripts/audit-canonical-gazetteer.mjs",
    "plan:gazetteer-sources": "node ./scripts/plan-gazetteer-source-jobs.mjs",
    "triage:gazetteer": "node ./scripts/triage-gazetteer-matches.mjs",
    "proxy": "node ./proxy/enrichment-proxy.mjs",
    "dev": "npm run build:db && vite",
    "build": "npm run build:db && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,md,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css,md,json}'",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.28.0",
    "@mapbox/vector-tile": "^1.3.1",
    "@samvera/clover-iiif": "3.3.0",
    "@types/jszip": "^3.4.1",
    "@types/react-select": "^5.0.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xenova/transformers": "^2.17.2",
    "fuse.js": "^7.0.0",
    "h3-js": "^4.1.0",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "maplibre-gl": "^4.7.1",
    "p-limit": "^7.2.0",
    "pbf": "^3.2.1",
    "pmtiles": "^4.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.0.0",
    "react-select": "^5.10.2",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.6.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-v8": "4.0.16",
    "autoprefixer": "^10.4.20",
    "duckdb": "^1.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-complexity": "^1.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.5.0",
    "jscpd": "^4.0.5",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.51.0",
    "vite": "^8.0.6",
    "vitest": "^4.0.16"
  }
}
